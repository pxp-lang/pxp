{
    "name": "vscode-pxp",
    "displayName": "vscode-pxp",
    "description": "Support for the PXP language.",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "pxp",
            "aliases": ["PXP", "pxp"],
            "extensions": [".pxp"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "pxp",
            "scopeName": "source.pxp",
            "path": "./syntaxes/pxp.tmLanguage.json"
        }]
    }
}