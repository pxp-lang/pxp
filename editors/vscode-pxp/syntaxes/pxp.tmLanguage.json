{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "PXP",
	"scopeName": "source.pxp",
	"patterns": [
		{
			"include": "#tags"
		},
        {
            "include": "#namespace"
        },
        {
            "include": "#named-arguments"
        },
        {
            "include": "#comments"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#operators"
        },
        {
            "include": "#type"
        },
        {
            "include": "#function-call"
        },
		{
			"include": "#var_language"
		},
		{
			"include": "#var_basic"
		}
    ],
    "repository": {
		"tags": {
			"patterns": [
				{
					"match": "(<\\?php|<\\?=|<\\?|\\?>)",
					"name": "punctuation.definition.tag.pxp"
				}
			]
		},
		"var_basic": {
            "patterns": [
                {
                    "match": "(?i)(\\$+)[a-z_\\x{7f}-\\x{10ffff}][a-z0-9_\\x{7f}-\\x{10ffff}]*",
                    "name": "variable.other.pxp",
                    "captures": {
                        "1": {
                            "name": "punctuation.definition.variable.pxp"
                        }
                    }
                }
            ]
        },
		"var_language": {
            "match": "(\\$)this\\b",
            "name": "variable.language.this.php",
            "captures": {
                "1": {
                    "name": "punctuation.definition.variable.php"
                }
            }
        },
        "class-name": {
            "patterns": [
                {
                    "begin": "\\b(?i)(?<!\\$)(?=[\\\\a-zA-Z_])",
                    "end": "(?i)([a-z_][a-z_0-9]*)?(?=[^a-z0-9_\\\\])\\b",
                    "endCaptures": {
                        "1": {
                            "name": "entity.name.class.pxp"
                        }
                    },
                    "patterns": [
                        {
                            "include": "#namespace"
                        }
                    ]
                }
            ]
        },
        "type": {
            "name": "support.type.pxp",
            "patterns": [
                {
                    "match": "\\b(?:void|true|false|null|never|float|bool|int|string|dict|vec|object|mixed|nonnull|resource|self|static|parent|iterable)\\b",
                    "name": "support.type.pxp"
                },
                {
                    "begin": "([A-Za-z_][A-Za-z0-9_]*)<",
                    "beginCaptures": {
                        "1": {
                            "name": "support.class.pxp"
                        }
                    },
                    "end": ">",
                    "patterns": [
                        {
                            "include": "#type-annotation"
                        }
                    ]
                },
                {
                    "begin": "(shape\\()",
                    "end": "((,|\\.\\.\\.)?\\s*\\))",
                    "endCaptures": {
                        "1": {
                            "name": "keyword.operator.key.pxp"
                        }
                    },
                    "name": "storage.type.shape.pxp",
                    "patterns": [
                        {
                            "include": "#type-annotation"
                        },
                        {
                            "include": "#strings"
                        },
                        {
                            "include": "#constants"
                        }
                    ]
                },
                {
                    "begin": "\\(",
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#type-annotation"
                        }
                    ]
                },
                {
                    "begin": "\\(fn\\(",
                    "end": "\\)",
                    "patterns": [
                        {
                            "include": "#type-annotation"
                        }
                    ]
                },
                {
                    "include": "#class-name"
                },
                {
                    "include": "#comments"
                }
            ]
        },
        "namespace": {
            "begin": "(?i)((namespace)|[a-z0-9_]+)?(\\\\)(?=.*?[^a-z_0-9\\\\])",
            "beginCaptures": {
                "1": {
                    "name": "entity.name.type.namespace.pxp"
                },
                "3": {
                    "name": "punctuation.separator.inheritance.pxp"
                }
            },
            "end": "(?i)(?=[a-z0-9_]*[^a-z0-9_\\\\])",
            "name": "support.other.namespace.pxp",
            "patterns": [
                {
                    "name": "entity.name.type.namespace.pxp",
                    "match": "(?i)[a-z0-9_]+(?=\\\\)"
                },
                {
                    "captures": {
                        "1": {
                            "name": "punctuation.separator.inheritance.pxp"
                        }
                    },
                    "match": "(?i)(\\\\)"
                }
            ]
        },
        "named-arguments": {
            "match": "(?i)(?<=^|\\(|,)\\s*([a-z_\\x{7f}-\\x{10ffff}][a-z0-9_\\x{7f}-\\x{10ffff}]*)\\s*(:)(?!:)",
            "captures": {
                "1": {
                    "name": "entity.name.variable.parameter.pxp"
                },
                "2": {
                    "name": "punctuation.separator.colon.pxp"
                }
            }
        },
        "comments": {
            "patterns": [
                {
                    "begin": "/\\*",
                    "captures": {
                        "0": {
                            "name": "punctuation.definition.comment.pxp"
                        }
                    },
                    "end": "\\*/",
                    "name": "comment.block.pxp"
                },
                {
                    "begin": "(^[ \\t]+)?(?=//)",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.whitespace.comment.leading.pxp"
                        }
                    },
                    "end": "(?!\\G)",
                    "patterns": [
                        {
                            "begin": "//",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.definition.comment.pxp"
                                }
                            },
                            "end": "\\n",
                            "name": "comment.line.double-slash.pxp"
                        }
                    ]
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.pxp",
                    "match": "\\b(break|continue|do|else|elseif|for|if|while|foreach|match|return|try|yield|from|catch|finally|default|exit)\\b"
                },
                {
                    "name": "storage.decl.pxp",
                    "match": "\\b(const|enum|class|interface|trait|namespace|type|case|function|fn)\\b"
                },
                {
                    "name": "storage.modifier.pxp",
                    "match": "\\b(final|abstract|static|readonly|public|private|protected)\\b"
                },
                {
                    "name": "keyword.other.pxp",
                    "match": "\\b(as|extends|implements|use|clone|new|echo)\\b"
                }
            ]
        },
        "function-call": {
            "patterns": [
                {
                    "begin": "(?i)(?=\\\\?[a-z_0-9\\\\]+\\\\[a-z_][a-z0-9_]*\\s*(\\(|(::<)))",
                    "comment": "Functions in a user-defined namespace (overrides any built-ins)",
                    "end": "(?=\\s*(\\(|(::<)))",
                    "patterns": [
                        {
                            "include": "#user-function-call"
                        }
                    ]
                },
                {
                    "begin": "(?i)(\\\\)?(?=\\b[a-z_][a-z_0-9]*\\s*(\\(|(::<)))",
                    "beginCaptures": {
                        "1": {
                            "name": "punctuation.separator.inheritance.pxp"
                        }
                    },
                    "comment": "Root namespace function calls (built-in or user)",
                    "end": "(?=\\s*(\\(|(::<)))",
                    "patterns": [
                        {
                            "include": "#user-function-call"
                        }
                    ]
                }
            ]
        },
        "user-function-call": {
            "begin": "(?i)(?=[a-z_0-9\\\\]*[a-z_][a-z0-9_]*\\s*\\()",
            "end": "(?i)[a-z_][a-z_0-9]*(?=\\s*\\()",
            "endCaptures": {
                "0": {
                    "name": "entity.name.function.pxp"
                }
            },
            "name": "meta.function-call.pxp",
            "patterns": [
                {
                    "include": "#namespace"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.single.pxp",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "match": "\\\\[\\\\']",
                            "name": "constant.character.escape.pxp"
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.pxp",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#interpolation"
                        }
                    ]
                }
            ]
        },
        "interpolation": {
            "patterns": [
                {
                    "comment": "Interpolating octal values e.g. \\01 or \\07.",
                    "match": "\\\\[0-7]{1,3}",
                    "name": "constant.numeric.octal.pxp"
                },
                {
                    "comment": "Interpolating hex values e.g. \\x1 or \\xFF.",
                    "match": "\\\\x[0-9A-Fa-f]{1,2}",
                    "name": "constant.numeric.hex.pxp"
                },
                {
                    "comment": "Escaped characters in double-quoted strings e.g. \\n or \\t.",
                    "match": "\\\\[nrt\\\\\\$\\\"]",
                    "name": "constant.character.escape.pxp"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "match": "0[xX][0-9a-fA-F]+(?:_[0-9a-fA-F]+)*",
                    "name": "constant.numeric.hex.pxp"
                },
                {
                    "match": "0[bB][01]+(?:_[01]+)*",
                    "name": "constant.numeric.binary.pxp"
                },
                {
                    "match": "0[oO][0-7]+(?:_[0-7]+)*",
                    "name": "constant.numeric.octal.pxp"
                },
                {
                    "match": "0(?:_?[0-7]+)+",
                    "name": "constant.numeric.octal.pxp"
                },
                {
                    "match": "(?x)\n(?:\n  (?:[0-9]+(?:_[0-9]+)*)?(\\.)[0-9]+(?:_[0-9]+)*(?:[eE][+-]?[0-9]+(?:_[0-9]+)*)?| # .3\n  [0-9]+(?:_[0-9]+)*(\\.)(?:[0-9]+(?:_[0-9]+)*)?(?:[eE][+-]?[0-9]+(?:_[0-9]+)*)?| # 3.\n  [0-9]+(?:_[0-9]+)*[eE][+-]?[0-9]+(?:_[0-9]+)*                                   # 2e-3\n)",
                    "name": "constant.numeric.decimal.pxp",
                    "captures": {
                        "1": {
                            "name": "punctuation.separator.decimal.period.pxp"
                        },
                        "2": {
                            "name": "punctuation.separator.decimal.period.pxp"
                        }
                    }
                },
                {
                    "match": "0|[1-9](?:_?[0-9]+)*",
                    "name": "constant.numeric.decimal.pxp"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "comment": "assignment operators",
                    "name": "keyword.assignments.pxp",
                    "match": "(\\+=|-=|\\*=|/=|%=|\\^=|&&=|<=|>=|&=|\\|=|<<=|>>=|\\?\\?=)"
                },
                {
                    "comment": "logical operators",
                    "name": "keyword.operators.pxp",
                    "match": "(\\^|\\||\\|\\||&&|>>|<<|&|~|<<|>>|>|<|<=>|\\?\\?|\\?|:|\\?:)(?!=)"
                },
                {
                    "comment": "comparison operators",
                    "name": "keyword.operator.comparison.pxp",
                    "match": "(==|===|!==|!=|<=|>=|<|>)(?!=)"
                },
                {
                    "comment": "math operators",
                    "name": "keyword.operator.math.pxp",
                    "match": "(([+%]|(\\*(?!\\w)))(?!=))|(-(?!>))|(/(?!/))"
                },
                {
                    "comment": "single equal assignment operator",
                    "name": "keyword.operator.assignment.pxp",
                    "match": "(?<![<>])=(?!=|>)"
                },
                {
                    "comment": "less than, greater than (special case)",
                    "match": "(?:\\b|(?:(\\))|(\\])|(\\})))[ \\t]+([<>])[ \\t]+(?:\\b|(?:(\\()|(\\[)|(\\{)))",
                    "captures": {
                        "1": {
                            "name": "punctuation.brackets.round.pxp"
                        },
                        "2": {
                            "name": "punctuation.brackets.square.pxp"
                        },
                        "3": {
                            "name": "punctuation.brackets.curly.pxp"
                        },
                        "4": {
                            "name": "keyword.operator.comparison.pxp"
                        },
                        "5": {
                            "name": "punctuation.brackets.round.pxp"
                        },
                        "6": {
                            "name": "punctuation.brackets.square.pxp"
                        },
                        "7": {
                            "name": "punctuation.brackets.curly.pxp"
                        }
                    }
                },
                {
                    "comment": "arrow method call, arrow property access",
                    "name": "keyword.operator.arrow.pxp",
                    "match": "(?x)\n(?:\n  -> | \\?-> \n)"
                },
                {
                    "comment": "double arrow key-value pair",
                    "name": "keyword.operator.double-arrow.pxp",
                    "match": "(?x)\n(?:\n  =>\n)"
                },
                {
                    "comment": "static method call, static property access",
                    "name": "keyword.operator.static.pxp",
                    "match": "(?x)\n(?:\n  ::\n)"
                },
                {
                    "comment": "closure creation",
                    "name": "keyword.operator.closure.pxp",
                    "match": "(?x)\n(?:\n  \\(\\.\\.\\.\\)\n)"
                },
                {
                    "comment": "spread operator",
                    "name": "keyword.operator.spread.pxp",
                    "match": "(?x)\n(?:\n  \\.\\.\\.\n)"
                },
                {
                    "comment": "namespace operator",
                    "name": "keyword.operator.namespace.pxp",
                    "match": "\\\\"
                }
            ]
        }
    }
}